/**
 * ClientConfig.h  —  Optional compile-time overrides for the TankAlarm Client
 *
 * Copy this file to "ClientConfig.h" in the same folder and edit the values
 * below.  The file is automatically picked up at compile time via __has_include.
 *
 * Any value defined here takes effect as the *initial default* when no saved
 * configuration exists yet (first boot / factory reset).  Values can still be
 * changed at runtime by pushing a new config from the server's Config Generator.
 *
 * NOTE: ClientConfig.h is listed in .gitignore so your credentials are never
 *       committed to version control.
 */

#ifndef CLIENT_CONFIG_H
#define CLIENT_CONFIG_H

// Blues Notehub Product UID  — required for Notecard communication
// Must match the server's Product UID for client-server routing to work.
// Format: com.company.product:project
#define DEFAULT_PRODUCT_UID "com.your-company.your-product:your-project"

#endif // CLIENT_CONFIG_H
